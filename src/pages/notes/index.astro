---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import PostCard from '@/components/PostCard.astro';
import CategoryNav from '@/components/CategoryNav.astro';
import Pagination from '@/components/Pagination.astro';
import { CATEGORIES, getCategory, type CategorySlug } from '@/utils/category';
import { NOTES_PAGE_SIZE, SITE_TITLE } from '@/consts';

const isProd = import.meta.env.PROD;
const notes = (
  await getCollection('notes', ({ data }) => (isProd ? !data.draft : true))
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const counts: Partial<Record<CategorySlug, number>> = {};
for (const c of CATEGORIES) counts[c.slug] = 0;
for (const n of notes) {
  const c = getCategory(n.data.tags);
  counts[c] = (counts[c] ?? 0) + 1;
}

const lastPage = Math.max(1, Math.ceil(notes.length / NOTES_PAGE_SIZE));
const data = notes.slice(0, NOTES_PAGE_SIZE);
const page = { currentPage: 1, lastPage };
---

<Layout title={`Notes · ${SITE_TITLE}`}>
  <header class="mb-6">
    <h1 class="text-2xl font-semibold tracking-tight">Notes</h1>
    <p class="mt-1 text-sm text-neutral-500">個人文章</p>
  </header>

  <div class="md:flex md:gap-10">
    <CategoryNav counts={counts} total={notes.length} active="all" />

    <div class="mt-6 min-w-0 flex-1 md:mt-0">
      {data.length === 0 && <p class="text-sm text-neutral-500">還沒有文章。</p>}

      {data.map((n) => (
        <PostCard
          href={`/notes/${n.id}`}
          title={n.data.title}
          description={n.data.description}
          pubDate={n.data.pubDate}
          tags={n.data.tags}
        />
      ))}

      <Pagination page={page} />
    </div>
  </div>
</Layout>
