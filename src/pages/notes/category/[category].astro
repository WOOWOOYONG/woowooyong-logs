---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import PostCard from '@/components/PostCard.astro';
import CategoryNav from '@/components/CategoryNav.astro';
import Pagination from '@/components/Pagination.astro';
import {
  CATEGORIES,
  getCategory,
  getCategoryName,
  type CategorySlug,
} from '@/utils/category';
import { NOTES_PAGE_SIZE, SITE_TITLE } from '@/consts';

export async function getStaticPaths() {
  const isProd = import.meta.env.PROD;
  const notes = (
    await getCollection('notes', ({ data }) => (isProd ? !data.draft : true))
  ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  const counts: Partial<Record<CategorySlug, number>> = {};
  for (const c of CATEGORIES) counts[c.slug] = 0;
  const byCat: Partial<Record<CategorySlug, typeof notes>> = {};
  for (const n of notes) {
    const c = getCategory(n.data.tags);
    counts[c] = (counts[c] ?? 0) + 1;
    (byCat[c] ??= []).push(n);
  }

  return CATEGORIES.map((c) => {
    const items = byCat[c.slug] ?? [];
    const lastPage = Math.max(1, Math.ceil(items.length / NOTES_PAGE_SIZE));
    return {
      params: { category: c.slug },
      props: {
        slug: c.slug,
        items: items.slice(0, NOTES_PAGE_SIZE),
        lastPage,
        counts,
        total: notes.length,
      },
    };
  });
}

const { slug, items, lastPage, counts, total } = Astro.props;
const name = getCategoryName(slug);
const page = { currentPage: 1, lastPage };
---

<Layout title={`${name} · Notes · ${SITE_TITLE}`}>
  <header class="mb-6">
    <h1 class="text-2xl font-semibold tracking-tight">Notes</h1>
    <p class="mt-1 text-sm text-neutral-500">分類：{name}</p>
  </header>

  <div class="md:flex md:gap-10">
    <CategoryNav counts={counts} total={total} active={slug} />

    <div class="mt-6 min-w-0 flex-1 md:mt-0">
      {items.length === 0 && (
        <p class="text-sm text-neutral-500">此分類尚無文章。</p>
      )}

      {items.map((n) => (
        <PostCard
          href={`/notes/${n.id}`}
          title={n.data.title}
          description={n.data.description}
          pubDate={n.data.pubDate}
          tags={n.data.tags}
        />
      ))}

      <Pagination page={page} basePath={`/notes/category/${slug}`} />
    </div>
  </div>
</Layout>
