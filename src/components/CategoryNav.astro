---
import { CATEGORIES, type CategorySlug } from '@/utils/category';

interface Props {
  counts: Partial<Record<CategorySlug, number>>;
  total: number;
  active?: CategorySlug | 'all';
}
const { counts, total, active = 'all' } = Astro.props;

const items = [
  { slug: 'all' as const, name: 'All', href: '/notes', count: total },
  ...CATEGORIES.map((c) => ({
    slug: c.slug,
    name: c.name,
    href: `/notes/category/${c.slug}`,
    count: counts[c.slug] ?? 0,
  })),
];
---

<nav
  class="md:sticky md:top-6 md:w-44 md:shrink-0 md:self-start"
  aria-label="Categories"
>
  <p class="mb-2 hidden text-xs font-medium tracking-wide text-neutral-400 uppercase md:block">
    Categories
  </p>

  <ul class="flex gap-1 overflow-x-auto pb-1 md:block md:space-y-1 md:overflow-visible md:pb-0">
    {items.map((it) => (
      <li class="shrink-0 md:shrink">
        <a
          href={it.href}
          aria-current={active === it.slug ? 'page' : undefined}
          class:list={[
            'flex items-center justify-between gap-3 rounded-full px-3 py-1.5 text-sm whitespace-nowrap md:rounded-md',
            active === it.slug
              ? 'bg-neutral-900 text-white'
              : 'text-neutral-700 hover:bg-neutral-100',
          ]}
        >
          <span>{it.name}</span>
          <span
            class:list={[
              'text-xs',
              active === it.slug ? 'text-neutral-300' : 'text-neutral-400',
            ]}
          >{it.count}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>
