---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from './Layout.astro';
import TagList from '@/components/TagList.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  cover: ImageMetadata;
  tags?: string[];
  link?: string;
  repo?: string;
}
const { title, description, pubDate, cover, tags = [], link, repo } = Astro.props;
const dateStr = pubDate.toISOString().slice(0, 10);
---

<Layout title={title} description={description}>
  <article>
    <header class="mb-8">
      <div class="mb-6 overflow-hidden rounded-xl border border-neutral-200">
        <Image src={cover} alt={title} class="w-full object-cover" widths={[640, 1080, 1600]} />
      </div>
      <h1 class="text-3xl font-semibold tracking-tight">{title}</h1>
      <p class="mt-2 text-neutral-600">{description}</p>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-xs text-neutral-500">
        <time datetime={dateStr}>{dateStr}</time>
        <TagList tags={tags} size="xs" />
        {link && <a href={link} target="_blank" rel="noopener" class="underline underline-offset-4">Live ↗</a>}
        {repo && <a href={repo} target="_blank" rel="noopener" class="underline underline-offset-4">Repo ↗</a>}
      </div>
    </header>
    <div class="prose-basic">
      <slot />
    </div>
  </article>
</Layout>
