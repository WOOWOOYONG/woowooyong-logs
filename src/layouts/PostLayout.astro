---
import Layout from './Layout.astro';
import TagList from '@/components/TagList.astro';
import TableOfContents from '@/components/TableOfContents.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  headings?: Heading[];
}
const { title, description, pubDate, tags = [], headings = [] } = Astro.props;
const dateStr = pubDate.toISOString().slice(0, 10);
---

<Layout title={title} description={description}>
  <div class="lg:flex lg:gap-10">
    <article class="min-w-0 flex-1">
      <header class="mb-8 border-b border-neutral-100 pb-6">
        <h1 class="text-3xl font-semibold tracking-tight">{title}</h1>
        {description && <p class="mt-2 text-neutral-600">{description}</p>}
        <div class="mt-4 flex items-center gap-3 text-xs text-neutral-500">
          <time datetime={dateStr}>{dateStr}</time>
          <TagList tags={tags} size="xs" />
        </div>
      </header>
      <div class="prose-basic">
        <slot />
      </div>
    </article>

    <TableOfContents headings={headings} />
  </div>
</Layout>
